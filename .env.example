# Bybit API Configuration (Latest Setup)
# Copy this to .env and add your NEW SECURE API keys
# NEVER share these keys or commit to git

BYBIT_API_KEY=your_new_secure_bybit_api_key_here
BYBIT_API_SECRET=your_new_secure_bybit_secret_here

# Trading Configuration (Latest Settings)
USE_TESTNET=true
USE_REAL_EXCHANGE=false
EXCHANGE=bybit
STRATEGY=scalper70
INITIAL_CAPITAL=3.0
LEVERAGE=50
MAX_CONCURRENT_TRADES=10
TOP_N_SYMBOLS=60
